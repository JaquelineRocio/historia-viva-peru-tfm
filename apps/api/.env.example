PORT=3000
NODE_ENV=development

# PostgreSQL local. En Neon usar DATABASE_URL y PGSSLMODE=require.
PGHOST=localhost
PGPORT=5432
PGUSER=app_user
PGPASSWORD=app_pass
PGDATABASE=tfm_db
DB_SCHEMA=tfm_schema
# DATABASE_URL=postgresql://usuario:clave@host/db?sslmode=require
# PGSSLMODE=require

JWT_SECRET=cambia-esto-en-produccion
JWT_EXPIRES_IN=12h
WEB_ORIGIN=http://localhost:5173

# Cuenta pública: nunca debe ser administradora.
SEED_USERNAME=docente
SEED_PASSWORD=tfm2026
SEED_DISPLAY_NAME=Docente de demostración
SEED_ROLE=colaborador
# ADMIN_USERNAME=administrador
# ADMIN_PASSWORD=usa-una-clave-aleatoria

ML_SERVICE_URL=http://localhost:8000
# Producción: https://jaquelineramosvargas--historia-viva-peru-ml-ml-api.modal.run
ML_TIMEOUT_MS=600000
# ML_INTERNAL_TOKEN=token-compartido
# Producción Modal: autenticación perimetral que evita arranques no autorizados.
# MODAL_PROXY_TOKEN_ID=wk-...
# MODAL_PROXY_TOKEN_SECRET=ws-...

# Docker local: Redis/BullMQ. Render Free: database.
PROCESSING_QUEUE_DRIVER=redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Docker local: local. Producción gratuita: Supabase Storage mediante S3.
FILE_STORAGE_DRIVER=local
UPLOAD_ROOT=storage/uploads
# S3_ENDPOINT=https://PROJECT_REF.storage.supabase.co/storage/v1/s3
# S3_BUCKET=historia-viva-tfm
# S3_REGION=us-west-2
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Cuotas de demostración pública. Localmente DEMO_MODE=false conserva 50 MB.
DEMO_MODE=false
DEMO_MAX_PDF_MB=10
DEMO_MAX_SOURCES_PER_USER=3

# DDL_PATH=
