PORT=3000
NODE_ENV=development

# PostgreSQL local. En Neon usar DATABASE_URL y PGSSLMODE=require.
PGHOST=localhost
PGPORT=5432
PGUSER=app_user
PGPASSWORD=app_pass
PGDATABASE=tfm_db
DB_SCHEMA=tfm_schema
# DATABASE_URL=postgresql://usuario:clave@host/db?sslmode=require
# PGSSLMODE=require

JWT_SECRET=cambia-esto-en-produccion
JWT_EXPIRES_IN=12h
WEB_ORIGIN=http://localhost:5173

# Cuenta pública: nunca debe ser administradora.
SEED_USERNAME=docente
SEED_PASSWORD=tfm2026
SEED_DISPLAY_NAME=Docente de demostración
SEED_ROLE=colaborador
# ADMIN_USERNAME=administrador
# ADMIN_PASSWORD=usa-una-clave-aleatoria

ML_SERVICE_URL=http://localhost:8000
ML_TIMEOUT_MS=600000
# ML_INTERNAL_TOKEN=token-compartido

# Docker local: Redis/BullMQ. Render Free: database.
PROCESSING_QUEUE_DRIVER=redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Docker local: local. Producción gratuita: r2.
FILE_STORAGE_DRIVER=local
UPLOAD_ROOT=storage/uploads
# R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# R2_BUCKET=historia-viva
# R2_REGION=auto
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Cuotas de demostración pública. Localmente DEMO_MODE=false conserva 50 MB.
DEMO_MODE=false
DEMO_MAX_PDF_MB=10
DEMO_MAX_SOURCES_PER_USER=3

# DDL_PATH=
