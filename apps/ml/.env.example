# Servicio ML (FastAPI) — prefijo ML_
ML_HOST=0.0.0.0
ML_PORT=8000

# Token compartido con NestJS para autorizar llamadas internas.
# Si se define, todos los endpoints (salvo /health) exigen el header X-Internal-Token.
# Debe coincidir con ML_INTERNAL_TOKEN en apps/api/.env.
# ML_INTERNAL_TOKEN=cambia-esto

# Raíz de artefactos de modelos (relativa a apps/ml salvo ruta absoluta)
# ML_STORAGE_DIR=storage

# Modelo académico publicado en Hugging Face Hub. Si se define, se descarga y
# activa en segundo plano al arrancar el servicio.
# ML_DEFAULT_MODEL_REPO=Jaqueline98/historia-viva-beto-v1
# ML_DEFAULT_MODEL_PATH=storage/models/beto-v1-gold-source-aware

# Fallback Whisper (opcionales; requieren faster-whisper + yt-dlp + ffmpeg)
# ML_WHISPER_MODEL=small
# ML_WHISPER_DEVICE=cpu
# ML_WHISPER_COMPUTE_TYPE=int8
# ML_WHISPER_LANGUAGE=es
